<svg width="1200" height="400" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#667eea;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#764ba2;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f093fb;stop-opacity:1" />
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    <radialGradient id="personGlow">
      <stop offset="0%" style="stop-color:#fff;stop-opacity:0.8" />
      <stop offset="100%" style="stop-color:#fff;stop-opacity:0.2" />
    </radialGradient>
  </defs>
  
  <!-- Background -->
  <rect width="1200" height="400" fill="url(#bg)"/>
  
  <!-- Connection lines between mentor and student -->
  <g opacity="0.6">
    <path d="M 300 200 Q 600 150 900 200" stroke="#fff" stroke-width="2" fill="none" stroke-dasharray="5,5">
      <animate attributeName="stroke-dashoffset" from="0" to="10" dur="2s" repeatCount="indefinite"/>
    </path>
    <circle cx="600" cy="175" r="4" fill="#fff">
      <animate attributeName="opacity" values="0;1;0" dur="2s" repeatCount="indefinite"/>
    </circle>
  </g>
  
  <!-- Mentor figure -->
  <g transform="translate(250, 150)">
    <!-- Head -->
    <circle cx="0" cy="0" r="30" fill="url(#personGlow)" stroke="#fff" stroke-width="2"/>
    <!-- Body -->
    <ellipse cx="0" cy="80" rx="40" ry="60" fill="url(#personGlow)" stroke="#fff" stroke-width="2"/>
    <!-- Arms - teaching gesture -->
    <path d="M -30 60 Q -50 80 -30 100" stroke="#fff" stroke-width="3" fill="none"/>
    <path d="M 30 60 Q 60 40 80 60" stroke="#fff" stroke-width="3" fill="none"/>
    <!-- Knowledge symbols around mentor -->
    <g opacity="0.8">
      <text x="-60" y="-20" font-family="Arial" font-size="20" fill="#fff">+</text>
      <text x="40" y="-30" font-family="Arial" font-size="20" fill="#fff">=</text>
      <text x="-70" y="40" font-family="Arial" font-size="20" fill="#fff">÷</text>
      <text x="50" y="50" font-family="Arial" font-size="20" fill="#fff">×</text>
    </g>
  </g>
  
  <!-- Student figure -->
  <g transform="translate(950, 150)">
    <!-- Head -->
    <circle cx="0" cy="0" r="25" fill="url(#personGlow)" stroke="#fff" stroke-width="2"/>
    <!-- Body -->
    <ellipse cx="0" cy="70" rx="35" ry="50" fill="url(#personGlow)" stroke="#fff" stroke-width="2"/>
    <!-- Arms - learning gesture -->
    <path d="M -25 50 Q -35 70 -25 85" stroke="#fff" stroke-width="3" fill="none"/>
    <path d="M 25 50 Q 35 70 25 85" stroke="#fff" stroke-width="3" fill="none"/>
    <!-- Lightbulb above head (idea) -->
    <g transform="translate(0, -50)">
      <circle cx="0" cy="0" r="15" fill="#ffd700" opacity="0.8"/>
      <rect x="-5" y="10" width="10" height="8" fill="#ffd700" opacity="0.8"/>
      <line x1="-3" y1="18" x2="-3" y2="22" stroke="#ffd700" stroke-width="2"/>
      <line x1="3" y1="18" x2="3" y2="22" stroke="#ffd700" stroke-width="2"/>
      <!-- Light rays -->
      <g opacity="0.6">
        <line x1="0" y1="-25" x2="0" y2="-35" stroke="#ffd700" stroke-width="2"/>
        <line x1="18" y1="-7" x2="25" y2="-10" stroke="#ffd700" stroke-width="2"/>
        <line x1="-18" y1="-7" x2="-25" y2="-10" stroke="#ffd700" stroke-width="2"/>
        <line x1="13" y1="13" x2="18" y2="18" stroke="#ffd700" stroke-width="2"/>
        <line x1="-13" y1="13" x2="-18" y2="18" stroke="#ffd700" stroke-width="2"/>
      </g>
    </g>
  </g>
  
  <!-- Learning elements floating around -->
  <g opacity="0.5">
    <!-- Books -->
    <g transform="translate(500, 100)">
      <rect x="0" y="0" width="30" height="20" fill="#fff" rx="2"/>
      <rect x="2" y="2" width="26" height="2" fill="#667eea"/>
      <rect x="2" y="6" width="26" height="2" fill="#667eea"/>
      <rect x="2" y="10" width="26" height="2" fill="#667eea"/>
    </g>
    
    <g transform="translate(650, 120)">
      <rect x="0" y="0" width="25" height="18" fill="#fff" rx="2"/>
      <rect x="2" y="2" width="21" height="2" fill="#764ba2"/>
      <rect x="2" y="6" width="21" height="2" fill="#764ba2"/>
      <rect x="2" y="10" width="21" height="2" fill="#764ba2"/>
    </g>
    
    <!-- Progress bars -->
    <g transform="translate(450, 280)">
      <rect x="0" y="0" width="100" height="8" fill="#fff" opacity="0.3" rx="4"/>
      <rect x="0" y="0" width="75" height="8" fill="#00ff41" opacity="0.8" rx="4"/>
    </g>
    
    <g transform="translate(600, 300)">
      <rect x="0" y="0" width="80" height="8" fill="#fff" opacity="0.3" rx="4"/>
      <rect x="0" y="0" width="60" height="8" fill="#00ff41" opacity="0.8" rx="4"/>
    </g>
    
    <!-- Target/bullseye -->
    <g transform="translate(750, 250)">
      <circle cx="0" cy="0" r="20" fill="none" stroke="#fff" stroke-width="2" opacity="0.8"/>
      <circle cx="0" cy="0" r="12" fill="none" stroke="#fff" stroke-width="2" opacity="0.6"/>
      <circle cx="0" cy="0" r="6" fill="#fff" opacity="0.8"/>
    </g>
  </g>
  
  <!-- Speech/interaction bubbles -->
  <g opacity="0.7">
    <!-- Mentor speech -->
    <g transform="translate(350, 120)">
      <ellipse cx="0" cy="0" rx="60" ry="25" fill="#fff" opacity="0.8"/>
      <path d="M -20 15 L -10 25 L -5 15" fill="#fff" opacity="0.8"/>
      <text x="0" y="5" font-family="Arial" font-size="12" fill="#667eea" text-anchor="middle">Let me guide you!</text>
    </g>
    
    <!-- Student response -->
    <g transform="translate(850, 120)">
      <ellipse cx="0" cy="0" rx="50" ry="20" fill="#fff" opacity="0.8"/>
      <path d="M 15 12 L 25 20 L 20 12" fill="#fff" opacity="0.8"/>
      <text x="0" y="5" font-family="Arial" font-size="12" fill="#764ba2" text-anchor="middle">I understand!</text>
    </g>
  </g>
  
  <!-- Achievement badges -->
  <g opacity="0.6">
    <g transform="translate(550, 200)">
      <circle cx="0" cy="0" r="15" fill="#ffd700" opacity="0.8"/>
      <text x="0" y="5" font-family="Arial" font-size="16" font-weight="bold" fill="#fff" text-anchor="middle">A+</text>
    </g>
    
    <g transform="translate(620" y="180)">
      <circle cx="0" cy="0" r="12" fill="#00ff41" opacity="0.8"/>
      <text x="0" y="4" font-family="Arial" font-size="12" font-weight="bold" fill="#fff" text-anchor="middle">100</text>
    </g>
  </g>
  
  <!-- Main title -->
  <text x="600" y="180" font-family="Arial, sans-serif" font-size="48" font-weight="bold" 
        fill="#fff" text-anchor="middle" filter="url(#glow)">One-to-One Learning</text>
  <text x="600" y="220" font-family="Arial, sans-serif" font-size="24" 
        fill="#fff" text-anchor="middle" opacity="0.9">Personalized Mentorship & Guidance</text>
  <text x="600" y="250" font-family="Arial, sans-serif" font-size="18" 
        fill="#ffd700" text-anchor="middle" opacity="0.8">Your Personal Learning Journey</text>
</svg>
